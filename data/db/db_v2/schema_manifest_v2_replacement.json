        {
          "field_name": "candidate_source",
          "required": "no",
          "description": "Source mode such as llm_extracted or deterministic_table_addition.",
          "source_stage": "Stage2 LLM or deterministic",
          "normalization_later": "yes",
          "evidence_role": "provenance_hint",
          "notes": "Deterministic additive rows may override this."
