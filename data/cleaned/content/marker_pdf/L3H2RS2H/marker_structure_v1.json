        [
          52.294921875,
          709.0680999755859
        ]
      ],
      "text": "E-mail address: mauricio.barbosa@anf.pt (C.M. Barbosa).",
      "section_hierarchy": {
        "2": "/page/0/SectionHeader/15"
      }
    },
