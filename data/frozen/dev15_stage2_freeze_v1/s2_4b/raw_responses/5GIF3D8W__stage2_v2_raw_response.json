  "evidence_spans": [
    {
      "span_id": "s1",
      "source_region_type": "synthesis_method",
      "source_locator_text": "SYNTHESIS_METHOD_BLOCK",
      "supporting_text": "The optimized formulation was prepared using nanoprecipitation method as follows: polymer (50 mg) and etoposide (5 mg) were dissolved in acetone. Dichloromethane was used to dissolve PCL and etoposide in case of emulsion solvent evaporation method. Resulting organic phase was added slowly under moderate magnetic stirring into triple distilled wa- ter(TDW) containingF68asstabilizer(1.0%w/v).Thisaqueous phase immediately turns milky with formation of nanoparticle dispersion. The organic solvent was then removed by evaporat- ing under magnetic stirring or under reduced pressure at 35◦C for approximately 1 hr (Rotavapor, Buchi, Switzerland). Entire dis- persion was centrifuged at 14,000 rpm at 25◦C for 10 min (Cool- ing Compufuge, Remi, Mumbai) in three cycles. Supernatant was analyzed for free drug content and the sediment constituting nanoparticles was freeze-dried. For freeze-drying, prefreezing of samples was done at –20◦C for 20 hr, then the ﬂasks were connected to freeze-drier (Maxi Dry Lyo, Heto, Germany) un- der vacuum (1 mbar, –110◦C). The process was continued till free-ﬂowing powder was obtained."
    },
    {
      "span_id": "s2",
      "source_region_type": "synthesis_method",
      "source_locator_text": "SYNTHESIS_METHOD_BLOCK",
      "supporting_text": "Different formulation variables like polymer amount (25, 50, 100, and 200 mg), concentration of stabilizer (0.5, 0.75, 1.0, and 2.0% w/v), and etoposide amount (2.5, 5, 10, and 20 mg) were varied and the effect on size, zeta potential, and entrap- ment efﬁciency was studied."
    },
    {
      "span_id": "s3",
      "source_region_type": "synthesis_method",
      "source_locator_text": "SYNTHESIS_METHOD_BLOCK",
      "supporting_text": "Only one parameter was changed in each series of experiments."
    },
    {
      "span_id": "s4",
      "source_region_type": "synthesis_method",
      "source_locator_text": "SYNTHESIS_METHOD_BLOCK",
      "supporting_text": "Drug free nanoparticles were pre- pared by the same methods without the addition of etoposide and characterized."
    },
    {
      "span_id": "s5",
      "source_region_type": "synthesis_method",
      "source_locator_text": "SYNTHESIS_METHOD_BLOCK",
      "supporting_text": "Average particle diameter, polydispersity index, and surface potential for each batch of prepared nanoparticles were deter- mined by using Zetasizer 3000HS (Malvern Instruments, UK)."
    },
    {
      "span_id": "s6",
      "source_region_type": "synthesis_method",
      "source_locator_text": "SYNTHESIS_METHOD_BLOCK",
      "supporting_text": "Values reported are the mean and standard deviation of three batches of nanoparticles."
    },
    {
      "span_id": "s7",
      "source_region_type": "materials_procurement",
      "source_locator_text": "MATERIALS_PROCUREMENT_BLOCK",
      "supporting_text": "Pluronic F 68 (F68) were procured from Sigma-Aldrich Chemicals, USA."
    },
    {
      "span_id": "s8",
      "source_region_type": "materials_procurement",
      "source_locator_text": "MATERIALS_PROCUREMENT_BLOCK",
      "supporting_text": "PLGA 75/25 (Purasorb PDLGA ⃝ R 75/25, molecular weight of 10,000) and PLGA 85/15 (Purasorb PDLGA ⃝ R 85/15, molecular weight of 10,000) were generously gifted by Purac, The Netherlands."
    },
    {
      "span_id": "s9",
      "source_region_type": "experimental_design",
      "source_locator_text": "EXPERIMENTAL_DESIGN_BLOCK",
      "supporting_text": "En- trapment efﬁciency ranging from 57 to 80% was obtained for the formulations, and the percent drug content was low for all batches with a maximum of around 1.45 for PLGA 85/15 and PCL."
    },
    {
      "span_id": "s10",
      "source_region_type": "table_caption",
      "source_locator_text": "TABLE_SUMMARY data/cleaned/content_goren_2025/tables/5GIF3D8W/5GIF3D8W__table_04__pdf_table.csv",
      "supporting_text": "table_id: Table 4 - title_or_caption: Formulation table with drug/polymer/loading variables. - column_headers: Formulation characters for the optimized nanoparticle formulations - table_role_hint: formulation - first_column_row_labels_preview: 0, PLGA 50/50 (Mean ± SD), Empty, Diameter (nm), PIa, ZPb (mV), Recovery (%), Drug content (%), EEc (%)"
    },
    {
      "span_id": "s11",
      "source_region_type": "paragraph",
      "source_locator_text": "OPTIMIZATION_RESULT_BLOCK",
      "supporting_text": "Increase in concentration of F68 from 0.5 to 1.0% w/v made signiﬁcant decrease in size of nanoparticles prepared with all the polymers in the study. Above 1.0% w/v of F68, there was no sig- niﬁcant decrease in size of the particles. Therefore, 1.0% w/v of F68 was considered as optimum for the preparation of nanopar- ticles and used for optimized products."
    },
    {
      "span_id": "s12",
      "source_region_type": "paragraph",
      "source_locator_text": "OPTIMIZATION_RESULT_BLOCK",
      "supporting_text": "Polydispersity index values of the formulations prepared are less than 0.9 for all formulations prepared in the study indicating narrow and ho- homogenous size distribution."
    },
    {
      "span_id": "s13",
      "source_region_type": "paragraph",
      "source_locator_text": "OPTIMIZATION_RESULT_BLOCK",
      "supporting_text": "Particles prepared with F68 as sta- bilizer have signiﬁcant negative surface charge ranging around −33.38 to −18.91 mV for PLGA-copolymers and −33.14 to −23.62 mV for PCL."
    },
    {
      "span_id": "s14",
      "source_region_type": "paragraph",
      "source_locator_text": "OPTIMIZATION_RESULT_BLOCK",
      "supporting_text": "An increase in the polymer amount affected the morphology, particle size, polydispersity, zeta potential, drug content, and en- capsulation efﬁciency of the nanoparticles. Initially on increase from 25 to 50 mg, there was no signiﬁcant increase in mean size of the particles but polydispersity index was slightly increased. Nanoparticles prepared with 25 and 50 mg of polymer formed milky dispersions without any agglomerates. For formulations withPLGA-copolymers,increaseinamountto100mgincreased the size (167.8 and 235.4 nm for 100 and 200 mg, respectively, forPLGA50/50)"
    },
    {
      "span_id": "s15",
      "source_region_type": "paragraph",
      "source_locator_text": "PARAGRAPH_BLOCK",
      "supporting_text": "But in formulations prepared with PCL, agglomeration started with 100 mg and when increased to 200 mg, agglomeration was very high leading to precipitation of polymer into large ﬂakes."
    },
    {
      "span_id": "s16",
      "source_region_type": "paragraph",
      "source_locator_text": "PARAGRAPH_BLOCK",
      "supporting_text": "PLGA 50/50 (×24,000), (B) PLGA 75/25 (×20,000), (C) PLGA 85/15 (×21,000) and (D) PCL (×24,000)."
    },
    {
