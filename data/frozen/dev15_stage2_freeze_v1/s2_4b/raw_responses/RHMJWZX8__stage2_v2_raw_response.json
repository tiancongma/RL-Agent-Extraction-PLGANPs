  "evidence_spans": [
    {
      "span_id": "s1",
      "source_region_type": "paragraph",
      "source_locator_text": "SYNTHESIS_METHOD_BLOCK",
      "supporting_text": "Compared with AP solution, PLGA-NPs provided higher AUC, MRT, t1/2, but lower plasma clearance (CL) for both AP and PUE, indicating an increased drug exposure in blood circulation."
    },
    {
      "span_id": "s2",
      "source_region_type": "paragraph",
      "source_locator_text": "SYNTHESIS_METHOD_BLOCK",
      "supporting_text": "Following intravenous administration of AP-PLGA-NPs, the AUC0−∞values of AP and PUE were 5398.60 ± 724.77 and 15106.98 ± 3652.73 h ng/ml, which were 2.90- and 2.29-fold as great as those of AP solution, respectively."
    },
    {
      "span_id": "s3",
      "source_region_type": "paragraph",
      "source_locator_text": "SYNTHESIS_METHOD_BLOCK",
      "supporting_text": "The Cmax values of AP and PUE were similar in the two groups, suggesting a sustained release of the NP preparation."
    },
    {
