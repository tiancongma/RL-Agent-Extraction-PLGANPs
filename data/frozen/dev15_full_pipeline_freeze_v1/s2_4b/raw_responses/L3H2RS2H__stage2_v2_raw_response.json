  "evidence_spans": [
    {
      "span_id": "span_001",
      "source_region_type": "methods_sentence",
      "source_locator_text": "SYNTHESIS_METHOD_BLOCK",
      "supporting_text": "Experimental design: varying concentrations or batches."
    },
    {
      "span_id": "span_002",
      "source_region_type": "methods_sentence",
      "source_locator_text": "SYNTHESIS_METHOD_BLOCK",
      "supporting_text": "Preparation of nanocapsules XAN and 3-MeOXAN-containing PLGA nanocapsules were prepared by the interfacial polymer deposition technique described by Fessi et al. [19]."
    },
    {
      "span_id": "span_003",
      "source_region_type": "methods_sentence",
      "source_locator_text": "SYNTHESIS_METHOD_BLOCK",
      "supporting_text": "Brieﬂy, about 50 mg of polymer and 100 mg of soybean lecithin were dissolved in 10 mL of acetone."
    },
    {
      "span_id": "span_004",
      "source_region_type": "methods_sentence",
      "source_locator_text": "SYNTHESIS_METHOD_BLOCK",
      "supporting_text": "Different amounts of XAN or 3-MeOXAN were dissolved in 0.5–0.6 mL of Myritolw 318 and the solution obtained was added to the previously prepared acetonic solution."
    },
    {
      "span_id": "span_005",
      "source_region_type": "methods_sentence",
      "source_locator_text": "SYNTHESIS_METHOD_BLOCK",
      "supporting_text": "The ﬁnal solution was poured into 20 mL of an aqueous solution of Pluronicw F-68 0.5% (w/v) under moderate stirring, leading to the formation of the nanocapsules."
    },
    {
      "span_id": "span_006",
      "source_region_type": "methods_sentence",
      "source_locator_text": "MATERIALS_PROCUREMENT_BLOCK",
      "supporting_text": "Xanthone (XAN), PLGA (50:50) MW 50 000–75 000, Pluronic F-68, phosphate buffered saline tablets and soybean lecithin (40% purity by thin-layer chromatography) were purchased from Sigma-Aldrich Quı´mica (Sintra, Portugal)."
    },
    {
      "span_id": "span_007",
      "source_region_type": "table_caption",
      "source_locator_text": "MATERIALS_PROCUREMENT_BLOCK",
      "supporting_text": "Table 5 Mean diameter, polydispersity index (PI), zeta potential (z) and incorporation parameters of various nanocapsule formulations: empty nanocapsules (0.6 mL Myritol 318 and without xanthones), XAN-loaded nanocapsules (0.6 mL Myritol 318, XAN theoretical concentration of 1440 mg/mL) and 3-MeOXAN-loaded nanocapsules (0.6 mL Myritol 318, 3-MeOXAN theoretical concentration of 3360 mg/mL) Sample Theoretical con- centration (mg/mL) Final concentration (mg/mL) [n] Encapsulation efﬁciency (%) Diameter (nm) [n] PI z (mV) [n] Empty nanocapsules – – – 261G17 [5]"
    },
    {
      "span_id": "span_008",
      "source_region_type": "text_span",
      "source_locator_text": "FORMULATION_RESULT_BLOCK",
      "supporting_text": "The aim of the present work was to develop and characterize two different nanosystems, nanospheres and nanocapsules, containing either xanthone (XAN) or 3-methoxyxanthone (3-MeOXAN)"
    },
    {
      "span_id": "span_009",
      "source_region_type": "text_span",
      "source_locator_text": "FORMULATION_RESULT_BLOCK",
      "supporting_text": "made of poly(DL-lactide- co-glycolide) (PLGA), were prepared by the solvent displacement technique."
    },
    {
      "span_id": "span_010",
      "source_region_type": "text_span",
      "source_locator_text": "FORMULATION_RESULT_BLOCK",
      "supporting_text": "The nanospheres had a mean diameter !170 nm, a narrow size distribution (polydispersity index !0.1), and a negative surface charge (zeta potential !K36 mV)."
    },
    {
      "span_id": "span_011",
      "source_region_type": "text_span",
      "source_locator_text": "OPTIMIZATION_RESULT_BLOCK",
      "supporting_text": "Optimization result: best/highest/efficiency/loading outcome."
    },
    {
      "span_id": "span_012",
      "source_region_type": "text_span",
      "source_locator_text": "OPTIMIZATION_RESULT_BLOCK",
      "supporting_text": "For concentrations above 70 mg/mL both xanthones precipitated in the form of crystals, indicating that the maximum loading capacity of the carrier was reached."
    },
    {
      "span_id": "span_013",
      "source_region_type": "text_span",
      "source_locator_text": "OPTIMIZATION_RESULT_BLOCK",
      "supporting_text": "Thus, for the theoretical concentration of 60 mg/mL, the ﬁnal concentrations of encapsulated compounds were only of 20 mg/mL for XAN and 25 mg/ mL for 3-MeOXAN."
    },
    {
      "span_id": "span_014",
      "source_region_type": "text_span",
      "source_locator_text": "PARAGRAPH_BLOCK",
      "supporting_text": "Their incorporation efﬁciencies were 33% for XAN and 42% for 3-MeOXAN."
    },
    {
      "span_id": "span_015",
      "source_region_type": "text_span",
      "source_locator_text": "PARAGRAPH_BLOCK",
      "supporting_text": "Nanocapsules were also nanometric (mean size !300 nm) and exhibited a negative charge (zeta potential !K36 mV)."
    },
    {
      "span_id": "span_016",
      "source_region_type": "text_span",
      "source_locator_text": "PARAGRAPH_BLOCK",
      "supporting_text": "Their incorporation efﬁciency values (O77%) were higher than those corresponding to nanospheres for both xanthones."
    },
    {
      "span_id": "span_017",
      "source_region_type": "methods_sentence",
      "source_locator_text": "SYNTHESIS_METHOD_BLOCK",
      "supporting_text": "Empty nanocapsules were prepared according to the same procedure but omitting the xanthones in the organic phase."
    },
    {
      "span_id": "span_018",
      "source_region_type": "methods_sentence",
      "source_locator_text": "SYNTHESIS_METHOD_BLOCK",
      "supporting_text": "XAN and 3-MeOXAN nanoemulsions were prepared as nanocapsules, omitting the polymer in the organic phase."
    },
    {
      "span_id": "span_019",
      "source_region_type": "text_span",
      "source_locator_text": "FORMULATION_RESULT_BLOCK",
      "supporting_text": "The following characteristics of nanoparticle formulations were determined: particle size and morphology, zeta potential, incorporation efﬁciency, thermal behaviour, in vitro release proﬁles and physical stability at 4 8C."
    },
    {
      "span_id": "span_020",
      "source_region_type": "text_span",
      "source_locator_text": "PARAGRAPH_BLOCK",
      "supporting_text": "Nanocapsule formulations exhibited good physical stability at 4 8C during a 4-month period for XAN and during a 3-month period for 3-MeOXAN."
    }
  ],
